#!/usr/bin/env bash

set -euo pipefail

usage() {
    cat <<EOF
Usage: tmux-run [-h | --help] [-a | --attach] <command> [args...]

Start a tmux session running the given command.

Options:
  -h, --help      Show this help message
  -a, --attach    Immediately attach to new session
EOF
}

ATTACH=false

while [ $# -gt 0 ]; do
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        -a|--attach)
            ATTACH=true
            shift
            ;;
        -*)
            echo "Unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
        *)
            break
            ;;
    esac
    shift
done

if [ $# -lt 1 ]; then
    usage
    exit 1
fi

CMD="$1"
shift

SESSION_NAME="tmux-run-${CMD}"

if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    echo "Error: session '$SESSION_NAME' already exists" >&2
    exit 1
else
    tmux new-session -d -s "$SESSION_NAME" "$CMD" "$@"
    if $ATTACH; then
        tmux attach-session -t "$SESSION_NAME"
    fi
fi
