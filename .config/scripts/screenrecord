#!/usr/bin/bash
set -eo pipefail

target_dir="$HOME/Videos/screencasts"
target_basename="$(date +'%Y-%m-%d-%H%M%S')_screen"

mkdir -p "$target_dir"

temp=$(
  getopt -o 'hsg:ar:e:' \
    --long 'help,select,geometry,audio,framerate,encoding,no-dmabuf' \
    -n "screenrecord" \
    -- "$@"
)

if [ $? -ne 0 ]; then
  exit 1
fi

eval set -- "$temp"
unset temp

function usage() {
  cat <<-EOF
		USAGE:
		  screenrecord -s [options]

		MODES:
		  -s, --select
		      Select a region of the screen to record.
      -g, --geometry
          Specify the geometry of the region to record.
		
		OPTIONS:
		  -a, --audio
		      Record with audio.
		  -r, --framerate <rate>
		      Set the video framerate.
		  -e, --encoding
		      Set the video encoding.
      --no-dmabuf
          Disable the GPU copy and force a CPU one.
		  -h, --help
		      Display this help message.
EOF
}

function format_geometry() {
  local raw_geom="$1"

  if [ -z "$raw_geom" ]; then
    echo "Error: Geometry string cannot be empty." >&2
    exit 1
  fi

  # Use Perl to parse coords (X,Y) and dims (WxH), rounding WxH dimensions.
  perl -e '
      my $full_geom = shift;
      if ($full_geom =~ /^([^ ]+) ([^ ]+)$/) {
          my $coords = $1;
          my ($w, $h) = split(/x/, $2);

          # Function to round a number N to the nearest even integer.
          sub round_to_even {
              my ($n) = @_;
              return 2 * int(($n + 1) / 2);
          }

          my $new_w = round_to_even($w);
          my $new_h = round_to_even($h);

          print "$coords ${new_w}x${new_h}";
      } else {
           die "Invalid geometry format: $full_geom\n";
      }
  ' "$raw_geom"
}

mode=""
geometry=""
framerate=30
encoding="mp4"
flag_audio=""
flag_dmabuf=""

function set_mode() {
  if [ ! -z "$mode" ]; then
    echo "Modes $mode and $1 are exclusive!" >&2
    exit 1
  fi

  mode="$1"
}

while true; do
  case "$1" in
  '-s')
    set_mode "select"
    shift
    continue
    ;;
  '-g')
    # Geometry argument is expected as a single string in $2: "x,y WxH". Dimensions are rounded to the closest even number.
    if [ -z "$2" ]; then
      echo "Error: Geometry requires coordinates and dimensions." >&2
      exit 1
    fi

    geometry_str="$2"

    # Use the function to process geometry string
    geometry="$(format_geometry "$geometry_str")"
    shift 2
    set_mode "geometry"
    continue
    ;;
  '-a' | '--audio')
    default_sink_name="$(pactl info | grep "Default Sink:" | awk '{print $3}')"
    flag_audio="--audio=$default_sink_name.monitor"
    shift
    continue
    ;;
  '--no-dmabuf')
    flag_dmabuf="--no-dmabuf"
    shift
    continue
    ;;
  '-r' | '--framerate')
    framerate=$2
    shift 2
    continue
    ;;
  '-e' | '--encoding')
    encoding="$2"
    shift 2
    continue
    ;;
  '-h' | '--help')
    usage
    exit 1
    ;;
  '--')
    shift
    break
    ;;
  *)
    echo "Internal error" >&2
    exit 1
    ;;
  esac
done

case "$mode" in
'select')
  # Get geometry from slurp and process it
  slurped_geom="$(slurp)"
  formatted_geometry="$(format_geometry "$slurped_geom")"

  if [ "$XDG_SESSION_TYPE" = "x11" ]; then
    echo "Unimplemented session type" >&2
    exit 1
  else
    wf-recorder -g "$formatted_geometry" \
      "$flag_dmabuf" \
      -r "$framerate" \
      -f "$target_dir/$target_basename.$encoding" \
      "$flag_audio"
  fi
  ;;
'geometry')
  if [ "$XDG_SESSION_TYPE" = "x11" ]; then
    echo "Unimplemented session type" >&2
    exit 1
  else
    wf-recorder -g "$geometry" \
      "$flag_dmabuf" \
      -r "$framerate" \
      -f "$target_dir/$target_basename.$encoding" \
      "$flag_audio"
  fi
  ;;
*)
  echo "No mode selected!" >&2
  echo ""
  usage
  exit 1
  ;;
esac
