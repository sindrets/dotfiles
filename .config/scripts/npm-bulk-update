#!/usr/bin/env bash

show_help() {
    cat <<EOF
Usage: $0 [options] <package_name> <target_version>

Bulk update a package version across all package.json files.

Arguments:
  package_name        Name of the npm package to update (e.g., lodash)
  target_version      Target version to set (e.g., 4.17.21)

Options:
  -h, --help          Show this help message

Example:
  $0 lodash 4.17.21

This script updates the package in dependencies, devDependencies, and overrides
sections (exact version) and peerDependencies (with ^ prefix) of all
package.json files.
EOF
}

# --- ARGUMENT CHECK ---
for arg in "$@"; do
    case "$arg" in
        -h|--help)
            show_help
            exit 0
            ;;
    esac
done

if [ "$#" -ne 2 ]; then
    echo "❌ Error: Missing arguments."
    echo ""
    show_help
    exit 1
fi

TARGET_PKG=$1
TARGET_VER=$2
# ----------------------

echo "🚀 Starting bulk update for '$TARGET_PKG' to '$TARGET_VER'..."

find . -name "package.json" -not -path "*/node_modules/*" | while read -r pkg_json; do
    echo "📝 Processing $pkg_json..."

    jq --arg pkg "$TARGET_PKG" --arg ver "$TARGET_VER" \
        '(if (.dependencies | has($pkg)) then .dependencies[$pkg] = $ver else . end) |
         (if (.devDependencies | has($pkg)) then .devDependencies[$pkg] = $ver else . end) |
         (if (.peerDependencies | has($pkg)) then .peerDependencies[$pkg] = ("^" + $ver) else . end) |
         (if (.overrides | has($pkg)) then .overrides[$pkg] = $ver else . end)' \
        "$pkg_json" | sponge "$pkg_json"

done

echo "✅ All package.json files updated."
echo "📦 Running a single npm install at the root to sync lockfiles..."

npm install

echo "✨ Done!"
