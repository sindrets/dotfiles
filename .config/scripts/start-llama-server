#!/usr/bin/env bash

declare -A DEFAULT_FLAGS=(
  [--model]="$HOME/.lmstudio/models/unsloth/Qwen3.6-35B-A3B-MTP-GGUF/Qwen3.6-35B-A3B-UD-IQ2_M.gguf"
  [--port]="1234"
  [--ctx-size]="131072"
  [--gpu-layers]="40"
  [--threads]="9"
  [--parallel]="1"
  [--batch-size]="2048"
  [--ubatch-size]="512"
  [--flash-attn]="on"
  [--spec-type]="draft-mtp"
  [--spec-draft-n-max]="2"
  [--temp]="0.6"
  [--presence-penalty]="0.0"
  [--repeat-penalty]="1.05"
)

# more flags:
#
# --chat-template-kwargs '{"reasoning_effort": "medium"}'

declare -A FINAL_FLAGS

for key in "${!DEFAULT_FLAGS[@]}"; do
  FINAL_FLAGS["$key"]="${DEFAULT_FLAGS[$key]}"
done

POSITIONAL=()

# Merge defaults with user overrides via while loop
while [[ $# -gt 0 ]]; do
  case "$1" in
    --*=*)
      key="${1%%=*}"
      val="${1#*=}"
      FINAL_FLAGS[$key]="$val"
      shift
      ;;
    --*)
      FINAL_FLAGS[$1]="$2"
      shift 2
      ;;
    *)
      POSITIONAL+=("$1")
      shift
      ;;
  esac
done

# If positional args were passed, use the first as model
if [[ ${#POSITIONAL[@]} -gt 0 ]]; then
  FINAL_FLAGS["--model"]="${POSITIONAL[0]}"
fi

# Auto-detect mmproj file alongside the model
if [[ -z "${FINAL_FLAGS["--mmproj"]}" ]]; then
  model_dir="$(dirname "${FINAL_FLAGS["--model"]}")"
  mmproj_file="$(find "$model_dir" -maxdepth 1 -iname '*mmproj*' -type f | head -n 1)"
  if [[ -n "$mmproj_file" ]]; then
    FINAL_FLAGS["--mmproj"]="$mmproj_file"
  fi
fi

# Build the command line
ARGS=()
for key in "${!FINAL_FLAGS[@]}"; do
  value="${FINAL_FLAGS[$key]}"
  if [[ "$value" == "true" ]]; then
    ARGS+=("$key")
  elif [[ ! "$value" == "false" ]]; then
    ARGS+=("$key" "$value")
  fi
done

llama-server "${ARGS[@]}"
